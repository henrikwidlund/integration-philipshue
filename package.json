{
  "name": "uc-integration-philipshue",
  "version": "0.3.0",
  "description": "Philips Hue integration for Unfolded Circle",
  "main": "dist/src/driver.js",
  "type": "module",
  "scripts": {
    "format": "prettier --write .",
    "code-check": "prettier --check . && eslint .",
    "lint": "eslint --fix .",
    "test": "tsc && ava dist/test/**/*.js",
    "build": "tsc && cp -r src/locales dist/src/",
    "start": "npm run build && node dist/src/driver.js"
  },
  "author": "Unfolded Circle",
  "license": "MPL-2.0",
  "dependencies": {
    "@unfoldedcircle/integration-api": "^0.4.4",
    "axios": "^1.15.0",
    "bonjour-service": "^1.3.0",
    "eventsource": "^4.1.0",
    "i18n": "^0.15.3",
    "undici": "^7.24.8"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/i18n": "^0.13.12",
    "@types/node": "^22.10.2",
    "@types/qs": "^6.15.0",
    "ava": "^6.4.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.2"
  }
}
